---
// Instant redirect to /en/ (or /it/ for Italian users)
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0;url=/en/" />
    <script is:inline>
      const saved = localStorage.getItem('alexdevflow-lang');
      const browserLang = (navigator.language || 'en').slice(0, 2);
      if (saved === 'it' || (!saved && browserLang === 'it')) {
        window.location.replace('/it/');
      } else {
        window.location.replace('/en/');
      }
    </script>
  </head>
  <body></body>
</html>
