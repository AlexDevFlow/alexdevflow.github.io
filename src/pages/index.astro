---
// Language detection happens client-side via JS
// Fallback redirect to /en/ is handled by astro.config.mjs
---
<html>
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      const saved = localStorage.getItem('alexdevflow-lang');
      const browserLang = (navigator.language || 'en').slice(0, 2);
      const lang = saved || (browserLang === 'it' ? 'it' : 'en');
      window.location.replace('/' + lang + '/');
    </script>
  </head>
  <body></body>
</html>
